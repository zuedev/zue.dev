{
  "$schema": "node_modules/wrangler/config-schema.json",
  "compatibility_flags": ["nodejs_compat"],
  "compatibility_date": "2025-02-05",
  "name": "zue-dev",
  "main": "./server/index.js",
  "assets": {
    "directory": "./public/",
    "not_found_handling": "single-page-application",
    "binding": "ASSETS",
    "run_worker_first": true,
  },
  "observability": {
    "enabled": true,
  },
  "routes": [
    {
      "pattern": "zue.dev",
      "custom_domain": true,
    },
  ],
}
